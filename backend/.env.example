# DevFlow Backend Environment Variables

# The environment mode: 'development' or 'production'
NODE_ENV=production

# The port the backend server listens on
PORT=5000

# The connection string for your MongoDB Atlas Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/devflow?retryWrites=true&w=majority

# Secret key used for signing JWT tokens
JWT_SECRET=your_jwt_secret_key_here

# Expiration period of the JWT cookie (e.g. '30d' for 30 days)
JWT_EXPIRE=30d

# The URL of the Vercel frontend app (needed for CORS and Socket.io)
CLIENT_URL=https://devflow-frontend.vercel.app
